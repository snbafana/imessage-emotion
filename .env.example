# --- eve chat agent (the main chat UI) ---
# eve routes model calls through Vercel AI Gateway. Locally you need a gateway key;
# when deployed on Vercel it uses OIDC automatically (no key needed).
# Get one from the Vercel dashboard -> AI Gateway.
AI_GATEWAY_API_KEY=

# Model the eve agent uses (any AI Gateway "provider/model" string). Optional.
EVE_MODEL=anthropic/claude-sonnet-4.6

# --- Ax LLM scorer (analysis runs + agent/tools/score_window) ---
# The Ax structured scorer calls the provider directly. Set one of these; no
# lexical/model-free fallback is used for analysis runs.
OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# Optional model override for Ax analysis scripts.
# IMESSAGE_EMOTION_AX_MODEL=google/gemini-2.5-flash

# --- app database (optional) ---
# Where the app's synced SQLite lives. Defaults to
# ~/Library/Application Support/imessage-emotion/imessage-emotion.sqlite
# IMESSAGE_EMOTION_DB_PATH=
