{
  "runName": "ax-provider-selected-window-benchmark",
  "dataset": {
    "kind": "private",
    "privateConversationLimit": 2,
    "maxMessagesPerConversation": 600
  },
  "windowing": [
    { "size": 8, "stride": 4 }
  ],
  "selection": {
    "strategy": "top_shift",
    "maxWindowsPerConversation": 4,
    "candidateScorer": "roberta_emotion"
  },
  "deterministic": [
    "roberta_emotion",
    "emoji_keyword_features"
  ],
  "llm": [
    {
      "name": "ax_openai_gpt_4_1_nano",
      "provider": "openai",
      "model": "gpt-4.1-nano",
      "concurrency": 8,
      "maxWindows": 8,
      "maxTokens": 350
    },
    {
      "name": "ax_openrouter_qwen_next_nitro",
      "provider": "openrouter",
      "model": "qwen/qwen3-next-80b-a3b-instruct:nitro",
      "concurrency": 4,
      "maxWindows": 8,
      "maxTokens": 350
    },
    {
      "name": "ax_openrouter_mistral_small",
      "provider": "openrouter",
      "model": "mistralai/mistral-small-2603",
      "concurrency": 4,
      "maxWindows": 8,
      "maxTokens": 350
    }
  ]
}
