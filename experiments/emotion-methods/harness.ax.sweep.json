{
  "runName": "ax-slow-fast-context-window-sweep",
  "dataset": {
    "kind": "private",
    "privateConversationLimit": 2,
    "maxMessagesPerConversation": 600
  },
  "windowing": [
    { "size": 8, "stride": 4 },
    { "size": 16, "stride": 8 }
  ],
  "selection": {
    "strategy": "top_shift",
    "maxWindowsPerConversation": 4,
    "candidateScorer": "roberta_emotion"
  },
  "deterministic": [
    "roberta_emotion",
    "emoji_keyword_features"
  ],
  "llm": [
    {
      "name": "fast_qwen_selected_8x4_window_only",
      "provider": "openrouter",
      "model": "qwen/qwen3-next-80b-a3b-instruct:nitro",
      "runMode": "selected_windows",
      "window": { "size": 8, "stride": 4 },
      "contextMode": "window_only",
      "concurrency": 4,
      "maxWindows": 8,
      "maxTokens": 350
    },
    {
      "name": "fast_qwen_selected_8x4_prior_messages",
      "provider": "openrouter",
      "model": "qwen/qwen3-next-80b-a3b-instruct:nitro",
      "runMode": "selected_windows",
      "window": { "size": 8, "stride": 4 },
      "contextMode": "prior_messages",
      "contextMessages": 24,
      "maxContextChars": 6000,
      "concurrency": 4,
      "maxWindows": 8,
      "maxTokens": 350
    },
    {
      "name": "fast_openai_selected_16x8_prior_summary",
      "provider": "openai",
      "model": "gpt-4.1-nano",
      "runMode": "selected_windows",
      "window": { "size": 16, "stride": 8 },
      "contextMode": "prior_summary",
      "concurrency": 6,
      "maxWindows": 8,
      "maxTokens": 350
    },
    {
      "name": "slow_qwen_all_16x8_prior_summary_sample",
      "provider": "openrouter",
      "model": "qwen/qwen3-next-80b-a3b-instruct:nitro",
      "runMode": "all_windows",
      "window": { "size": 16, "stride": 8 },
      "contextMode": "prior_summary",
      "maxConversations": 2,
      "concurrency": 4,
      "maxWindows": 24,
      "maxTokens": 350
    },
    {
      "name": "slow_qwen_whole_conversation_full",
      "provider": "openrouter",
      "model": "qwen/qwen3-next-80b-a3b-instruct:nitro",
      "runMode": "whole_conversation",
      "contextMode": "full_conversation",
      "maxConversations": 2,
      "maxContextChars": 18000,
      "concurrency": 2,
      "maxWindows": 2,
      "maxTokens": 450
    },
    {
      "name": "slow_openai_whole_conversation_full",
      "provider": "openai",
      "model": "gpt-4.1-nano",
      "runMode": "whole_conversation",
      "contextMode": "full_conversation",
      "maxConversations": 2,
      "maxContextChars": 18000,
      "concurrency": 2,
      "maxWindows": 2,
      "maxTokens": 450
    }
  ]
}
